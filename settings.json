{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "NotebookEdit(*)",
      "WebFetch(*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(command:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(readlink:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(tar:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(gzip:*)",
      "Bash(gunzip:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(paste:*)",
      "Bash(jq:*)",
      "Bash(env:*)",
      "Bash(export:*)",
      "Bash(unset:*)",
      "Bash(source:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(next:*)",
      "Bash(tsc:*)",
      "Bash(prettier:*)",
      "Bash(eslint:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(vercel:*)",
      "Bash(brew:*)",
      "Bash(openssl:*)",
      "Bash(base64:*)",
      "Bash(shasum:*)",
      "Bash(md5:*)",
      "Bash(lsof:*)",
      "Bash(kill:*)",
      "Bash(ps:*)",
      "Bash(pgrep:*)",
      "Bash(sleep:*)",
      "Bash(xxd:*)",
      "Bash(open:*)",
      "Bash(claude:*)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(sw_vers:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(id:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(mktemp:*)",
      "Bash(test:*)",
      "Bash([:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Bash(pbcopy:*)",
      "Bash(pbpaste:*)",
      "Bash(launchctl:*)",
      "Bash(plutil:*)",
      "Bash(defaults:*)",
      "Bash(~/.claude/scripts/git-health-check.sh)",
      "Bash(~/.claude/scripts/task-executor.sh*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout .:*)",
      "Bash(git restore .:*)",
      "Bash(git clean -f:*)",
      "Bash(*| bash*)",
      "Bash(*| sh*)",
      "Bash(*| zsh*)",
      "Bash(*| eval*)",
      "Bash(*|bash*)",
      "Bash(*|sh*)",
      "Bash(*|zsh*)",
      "Bash(*|eval*)",
      "Bash(*| /bin/bash*)",
      "Bash(*| /bin/sh*)",
      "Bash(*| /bin/zsh*)",
      "Bash(*|/bin/bash*)",
      "Bash(*|/bin/sh*)",
      "Bash(*|/bin/zsh*)",
      "Bash(*> ~/.bashrc*)",
      "Bash(*>> ~/.bashrc*)",
      "Bash(*> ~/.zshrc*)",
      "Bash(*>> ~/.zshrc*)",
      "Bash(*> ~/.profile*)",
      "Bash(*>> ~/.profile*)",
      "Bash(*> ~/.bash_profile*)",
      "Bash(*>> ~/.bash_profile*)",
      "Bash(npm install -g:*)",
      "Bash(npm i -g:*)",
      "Bash(pip install --user:*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/pre-compact-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/context-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/context-status.sh"
  }
}
